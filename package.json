{
  "name": "openclaw-memory-fabric",
  "version": "1.6.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.32.1",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "build": "pnpm -r build",
    "clean": "pnpm -r exec rm -rf dist dist-test tsconfig.tsbuildinfo tsconfig.test.tsbuildinfo",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm -r test",
    "test:e2e": "node --test scripts/e2e/e2e.test.mjs",
    "lint": "eslint packages/*/src packages/*/test",
    "lint:fix": "eslint packages/*/src packages/*/test --fix",
    "format": "prettier --write \"packages/*/src/**/*.ts\" \"packages/*/test/**/*.ts\"",
    "format:check": "prettier --check \"packages/*/src/**/*.ts\" \"packages/*/test/**/*.ts\""
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^22.15.29",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.8.3",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.58.2"
  }
}
