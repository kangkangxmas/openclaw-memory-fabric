{
  "name": "openclaw-memory-fabric",
  "version": "1.8.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.32.1",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "build": "pnpm -C packages/web build && cp -r packages/web/dist/ packages/sidecar/public/ && pnpm -C packages/plugin build && pnpm -C packages/sidecar build",
    "build:web": "pnpm -C packages/web build && cp -r packages/web/dist/ packages/sidecar/public/",
    "clean": "pnpm -r exec rm -rf dist dist-test tsconfig.tsbuildinfo tsconfig.test.tsbuildinfo",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm -r test",
    "test:e2e": "node --test scripts/e2e/e2e.test.mjs",
    "v2:gray-smoke": "node scripts/v2-gray-smoke.mjs",
    "v2:commit-smoke": "node scripts/v2-commit-smoke.mjs",
    "v2:canary-monitor": "node scripts/v2-canary-monitor.mjs",
    "lint": "eslint packages/plugin/src packages/plugin/test packages/sidecar/src packages/sidecar/test",
    "lint:fix": "eslint packages/plugin/src packages/plugin/test packages/sidecar/src packages/sidecar/test --fix",
    "format": "prettier --write \"packages/*/src/**/*.ts\" \"packages/*/test/**/*.ts\"",
    "format:check": "prettier --check \"packages/*/src/**/*.ts\" \"packages/*/test/**/*.ts\""
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^22.15.29",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.8.3",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.58.2"
  }
}
