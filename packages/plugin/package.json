{
  "name": "@openclaw-memory-fabric/plugin",
  "version": "1.8.0",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "openclaw": {
    "plugin": true,
    "extensions": ["./dist/index.js"],
    "hooks": [
      "before_prompt_build",
      "agent_end",
      "before_tool_call",
      "after_tool_call"
    ],
    "configKey": "memory-fabric",
    "compat": {
      "pluginApi": ">=2026.5.25",
      "minGatewayVersion": "2026.5.25"
    }
  },
  "files": [
    "dist",
    "skills",
    "openclaw.plugin.json"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "tsc -p tsconfig.test.json && node --test dist-test/test/*.test.js",
    "lint": "eslint src test",
    "lint:fix": "eslint src test --fix",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\" \"test/**/*.ts\""
  },
  "dependencies": {
    "ajv": "^8.18.0",
    "ajv-formats": "^3.0.1"
  }
}
